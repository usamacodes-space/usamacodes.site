# Copy to .env.local for local development

# Canonical site URL (inlined at build). Must match your primary Vercel / Search Console domain.
# Examples: https://usamacodes.space  OR  https://usamacodes.site
NEXT_PUBLIC_SITE_URL=https://usamacodes.space

# Optional: override public contact email (default: hello@<host from NEXT_PUBLIC_SITE_URL>)
# NEXT_PUBLIC_CONTACT_EMAIL=

# Optional: Groq API for AI chat (rule-based fallback works without it)
GROQ_API_KEY=

# Contact form (Resend) — required for /api/contact to send mail
RESEND_API_KEY=

# Optional: where contact form notifications are delivered (default: hello@usamacodes.site)
CONTACT_TO_EMAIL=

# Optional: must match a domain verified in Resend (default: Portfolio Contact <noreply@usamacodes.site>)
RESEND_FROM=
